# Sheet to write into (the long ID from the sheet URL)
GOOGLE_SHEET_ID=

# Google credentials — pick ONE of the following:

# (A) Local dev: path to the downloaded service-account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=

# (B) Cloud (Railway/etc.): paste the entire JSON file contents as one value
# GOOGLE_CREDENTIALS_JSON=

# Shared secret the plugin sends in the x-api-key header
API_KEY=

# Comma-separated list of allowed origins for CORS, or * for any
ALLOWED_ORIGINS=*
